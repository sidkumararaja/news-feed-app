# Copy to .env (never committed) for local development.
# On Vercel, set these in Project Settings → Environment Variables instead.

# Required for live news. Get a free key at https://gnews.io — without it
# the app serves bundled sample articles.
GNEWS_API_KEY=

# Optional: minutes to cache GNews responses (default 60). Raise it if you
# have many topics and are brushing against the free tier's 100 req/day.
# GNEWS_CACHE_TTL_MINUTES=60

# Optional: durable storage on Vercel via Upstash Redis (REST). The Vercel
# Marketplace integration injects these automatically — either as KV_REST_API_*
# (Vercel's naming) or UPSTASH_REDIS_REST_* (Upstash's naming); the app accepts
# both. Without them, preferences fall back to a local JSON file in dev and
# /tmp on Vercel (which resets on cold starts).
# UPSTASH_REDIS_REST_URL=   (or KV_REST_API_URL)
# UPSTASH_REDIS_REST_TOKEN= (or KV_REST_API_TOKEN)
